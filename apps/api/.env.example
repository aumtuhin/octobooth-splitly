# Local dev uses the Postgres from docker-compose (`npm run db:up` at repo root).
# In production these point at Neon and are set as Fly secrets (see fly.toml).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/splitly
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/splitly
JWT_SECRET=replace-with-a-strong-secret
PORT=4000
UPLOAD_DIR=uploads
